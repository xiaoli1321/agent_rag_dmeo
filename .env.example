QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cgm_customer_support

QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_LLM_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=qwen3-vl-embedding

# Optional split-provider names. These take precedence over QWEN_* when set.
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen3-vl-embedding
EMBEDDING_VECTOR_SIZE=1024
RERANK_ENABLED=false
RERANK_API_BASE=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank

AGENT_TOP_K=4
AGENT_MIN_RELEVANCE_SCORE=0.35
AGENT_RETRIEVAL_STRATEGY=hybrid
AGENT_FUSION_ALPHA=0.7
# A CRAG retry is only triggered when all retrieved candidates are rejected.
AGENT_CORRECTIVE_RETRIES=1
AGENT_LLM_GRADERS_ENABLED=true
AGENT_RUN_LOG_ENABLED=true
AGENT_RUN_LOG_DIR=customer_agent_demo/data/runs

# recursive keeps the original baseline; structural is the recommended demo default;
# parent-child embeds child chunks while returning parent context for answers.
DEMO_CHUNKING_STRATEGY=structural
